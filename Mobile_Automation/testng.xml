<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ============================================================
  COLLECTION CENTER - TESTNG CONFIGURATION
  Serial Execution: One test at a time, NO parallel threads
  Listener: Auto-generates final HTML + TXT summary report
  ============================================================
-->
<suite name="Collection_Center_Suite"
       verbose="2"
       parallel="none"
       thread-count="1"
       preserve-order="true">

  <!-- ============ GLOBAL SUITE LISTENER ============ -->
  <listeners>
    <listener class-name="Listeners.TestSummaryListener"/>
  </listeners>

  <!-- ============ TEST GROUP 1: LOGIN ============ -->
  <test name="01_Login_Tests" preserve-order="true">
    <classes>
      <class name="Testcases.Collection_center_login"/>
    </classes>
  </test>


  <!-- ============ TEST GROUP 2: EDPU ============ -->
  <test name="02_EDPU_Tests" preserve-order="true">
    <classes>
      <class name="Testcases.edpu"/>
    </classes>
  </test>

  <!-- ============ TEST GROUP 3: DASHBOARD ============ -->
  <test name="03_Dashboard_Tests" preserve-order="true">
    <classes>
      <class name="Testcases.Testing_Dashboard_CC"/>
    </classes>
  </test>

  <!-- ============ TEST GROUP 4: COLLECTION CENTER ============ -->
  <test name="04_CollectionCenter_Tests" preserve-order="true">
    <classes>
      <class name="Testcases.Collection_center"/>
    </classes>
  </test>

  <!-- ============ TEST GROUP 5: MILK TESTING ============ -->
  <test name="05_MilkTesting_Tests" preserve-order="true">
    <classes>
      <class name="Testcases.Milk_Testing_For_Transporter"/>
    </classes>
  </test>

  <!-- ============ TEST GROUP 6: FARMER REGISTRATION ============ -->
  <test name="06_FarmerRegistration_Tests" preserve-order="true">
    <classes>
      <class name="Testcases.Farmer_Registration"/>
    </classes>
  </test>

</suite>
